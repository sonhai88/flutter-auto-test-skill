name: Flutter Auto Audit
on:
  pull_request:
    paths:
      - '**/*.dart'
      - 'pubspec.yaml'

jobs:
  audit:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Detect changed Dart files
        id: changed
        run: |
          CHANGED=$(git diff --name-only origin/${{ github.base_ref }}...HEAD -- '*.dart' | head -20)
          echo "files=$CHANGED" >> $GITHUB_OUTPUT

